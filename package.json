{
  "name": "dartscounter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "One·Two·One — Darts Practice PWA. Static Vue 3 + TypeScript webapp.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "format": "prettier --write \"**/*.{ts,vue,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,css,md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "icons": "tsx scripts/generate-icons.ts"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "pinia": "^2.3.1",
    "vue": "^3.5.32",
    "vue-router": "^4.5.1",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.14.0",
    "happy-dom": "^17.1.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.5",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.2.6"
  }
}
